---
import { getCollection } from 'astro:content';
import { getMediumPosts } from '../lib/medium';
import { SOCIAL_LINKS } from '../lib/data';
import { withBase } from '../lib/url';

const nativePosts = (await getCollection('blog', ({ data }) => !data.draft)).map((p) => ({
	title: p.data.title,
	url: withBase(`blog/${p.id}/`),
	date: p.data.date.toISOString().slice(0, 10),
	source: 'site' as const,
}));

const mediumPosts = (await getMediumPosts(6)).map((p) => ({ ...p, source: 'medium' as const }));

const entries = [...nativePosts, ...mediumPosts].sort((a, b) => (a.date < b.date ? 1 : -1));
---

<section id="writing" class="prose">
	<h2>Writing</h2>
	<p class="muted" style="margin-top: -0.5rem;">
		I write about Go, Rust, and databases for <a href={SOCIAL_LINKS.medium}>20,000+ monthly readers</a> on Medium.
	</p>

	<ul class="plain stack" style="gap: 1rem;">
		{entries.map((post) => (
			<li>
				<div class="row">
					<a class="entry-title" href={post.url} target={post.source === 'medium' ? '_blank' : undefined} rel={post.source === 'medium' ? 'noopener' : undefined}>
						{post.title}
					</a>
					<span class="entry-meta">{post.date}{post.source === 'medium' ? ' · Medium' : ''}</span>
				</div>
			</li>
		))}
	</ul>

	<p style="margin-top: 1.25rem;"><a href={withBase('blog/')}>All posts on this site →</a></p>
</section>
