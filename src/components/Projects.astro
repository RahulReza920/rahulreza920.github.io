---
import { PROJECTS } from '../lib/data';
---

<section>
	<h2>Projects</h2>
	<div class="stack">
		{PROJECTS.map((p) => (
			<div>
				<div class="row">
					<a class="entry-title" href={p.url}>{p.name}</a>
					<span class="entry-meta">{p.stack}</span>
				</div>
				<p style="margin-top: 0.4rem;">{p.description}</p>
			</div>
		))}
	</div>
</section>
