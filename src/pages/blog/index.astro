---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import { withBase } from '../../lib/url';
import { getMediumPosts } from '../../lib/medium';
import { SOCIAL_LINKS } from '../../lib/data';

const nativePosts = (await getCollection('blog', ({ data }) => !data.draft)).map((p) => ({
	title: p.data.title,
	description: p.data.description as string | undefined,
	url: withBase(`blog/${p.id}/`),
	date: p.data.date.toISOString().slice(0, 10),
	source: 'site' as const,
}));

const mediumPosts = (await getMediumPosts(8)).map((p) => ({
	...p,
	description: undefined as string | undefined,
	source: 'medium' as const,
}));

const entries = [...nativePosts, ...mediumPosts].sort((a, b) => (a.date < b.date ? 1 : -1));
---

<Base title="Writing — Rahul Reza">
	<h1>Writing</h1>
	<p class="muted" style="margin-top: 0.5rem;">
		I write about Go, Rust, and databases for <a href={SOCIAL_LINKS.medium}>20,000+ monthly readers</a> on Medium.
	</p>

	<ul class="plain stack" style="margin-top: 2rem; gap: 1.25rem;">
		{entries.map((post) => (
			<li>
				<div class="row">
					<a
						class="entry-title"
						href={post.url}
						target={post.source === 'medium' ? '_blank' : undefined}
						rel={post.source === 'medium' ? 'noopener' : undefined}
					>
						{post.title}
					</a>
					<span class="entry-meta">{post.date}{post.source === 'medium' ? ' · Medium' : ''}</span>
				</div>
				{post.description && <p style="margin-top: 0.35rem;">{post.description}</p>}
			</li>
		))}
	</ul>
</Base>
