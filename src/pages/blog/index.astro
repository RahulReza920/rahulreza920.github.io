---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import { withBase } from '../../lib/url';

const posts = (await getCollection('blog', ({ data }) => !data.draft)).sort(
	(a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
---

<Base title="Writing — Rahul Reza Roky">
	<a href={withBase('')}>← Home</a>
	<h1 style="margin-top: 1.5rem;">Writing</h1>

	<ul class="plain stack" style="margin-top: 2rem; gap: 1.25rem;">
		{posts.map((post) => (
			<li>
				<a class="entry-title" href={withBase(`blog/${post.id}/`)}>{post.data.title}</a>
				<div class="entry-meta">{post.data.date.toISOString().slice(0, 10)}</div>
				<p style="margin-top: 0.35rem;">{post.data.description}</p>
			</li>
		))}
	</ul>
</Base>
