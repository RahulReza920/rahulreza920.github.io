---
import { getCollection, render } from 'astro:content';
import Base from '../../layouts/Base.astro';
import { withBase } from '../../lib/url';

export async function getStaticPaths() {
	const posts = await getCollection('blog', ({ data }) => !data.draft);
	return posts.map((post) => ({
		params: { slug: post.id },
		props: { post },
	}));
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<Base title={`${post.data.title} — Rahul Reza`} description={post.data.description}>
	<a href={withBase('blog/')}>← All writing</a>
	<h1 style="margin-top: 1.5rem;">{post.data.title}</h1>
	<p class="entry-meta">{post.data.date.toISOString().slice(0, 10)}</p>
	<div style="margin-top: 2rem;">
		<Content />
	</div>
</Base>
